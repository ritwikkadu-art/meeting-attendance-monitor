# Copy this file to .env.yaml and fill in your actual values
# DO NOT commit .env.yaml to git!

# Google Calendar user email to impersonate (your work email)
GOOGLE_CALENDAR_USER_EMAIL: "your-email@yourdomain.com"

# Slack Bot OAuth Token (from Slack API dashboard)
# Should start with xoxb-
SLACK_BOT_TOKEN: "xoxb-your-slack-bot-token-here"

# Service account email (from Google Cloud Console)
SERVICE_ACCOUNT_EMAIL: "meeting-monitor@your-project-id.iam.gserviceaccount.com"

# Optional: Reminder timing configuration
# PRE_MEETING_REMINDER_HOURS: "2"      # Hours before meeting to send reminder (default: 2)
# POST_MEETING_REMINDER_MINUTES: "2"  # Minutes after meeting start to send reminder (default: 2)
